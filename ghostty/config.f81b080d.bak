# font-family = Victor Mono
font-family = Maple Mono NF
font-size = 13
font-thicken = true

link-url = true

theme = Catppuccin Mocha

# custom-shader = ../../Developer/ghostty-shaders/animated-gradient-shader.glsl
# custom-shader = ../../Developer/ghostty-shaders/bettercrt.glsl
# custom-shader = ../../Developer/ghostty-shaders/bloom.glsl
# custom-shader = ./center-gradient.glsl
# custom-shader = ../../Developer/ghostty-shaders/crt.glsl
# custom-shader = ../../Developer/ghostty-shaders/cubes.glsl
# custom-shader = ../../Developer/ghostty-shaders/dancing-lights.glsl
# custom-shader = ../../Developer/ghostty-shaders/dither.glsl
# custom-shader = ../../Developer/ghostty-shaders/drunkard.glsl
# custom-shader = ./gradient.glsl
# custom-shader = ../../Developer/ghostty-shaders/just-snow.glsl
# custom-shader = ../../Developer/ghostty-shaders/negative.glsl
# custom-shader = ../../Developer/ghostty-shaders/retro-terminal.glsl
# custom-shader = ../../Developer/ghostty-shaders/smoke-and-ghost.glsl
# custom-shader = ../../Developer/ghostty-shaders/starfield.glsl
# custom-shader = ../../Developer/ghostty-shaders/starfield-colors.glsl
# custom-shader = ../../Developer/ghostty-shaders/tft.glsl
# custom-shader = ./transparent-snow.glsl

macos-option-as-alt = true

auto-update = download

# The following command checks if tmux is installed.
# If tmux is installed, it automatically attaches to an existing tmux session.
# If no tmux session exists, a new one is created.
# If tmux is not installed, it simply starts zsh without tmux.
#
# For this to work properly, you need to make sure that your shell is configured
# for homebrew, so you should have this line:
# eval "$(/opt/homebrew/bin/brew shellenv)"
# In your ~/.zprofile file
# If you don't have that line, or if the file doesn't exist, run this:
# echo '' >>~/.zprofile && echo '# Configure shell for brew' >>~/.zprofile && echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >>~/.zprofile && eval "$(/opt/homebrew/bin/brew shellenv)"
#
# This assumes you installed tmux through brew if using macos
# command = zsh --login -c "if command -v tmux >/dev/null 2>&1; then tmux attach || tmux; else zsh; fi"
